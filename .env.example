# ============================================================
#  ProofSpeak — environment variables
#  Copy to .env.local and fill in. NEVER commit .env.local.
# ============================================================

# --- Neon Postgres (https://neon.tech) ---
# Project → Connection Details → "Connection string" (pooled).
DATABASE_URL="postgresql://user:password@ep-xxx.region.aws.neon.tech/neondb?sslmode=require"

# --- Vercel Blob (image storage) ---
# Vercel dashboard → Storage → create a Blob store → ".env.local" tab.
BLOB_READ_WRITE_TOKEN="vercel_blob_rw_xxxxxxxx"

# --- Resend (email notifications) ---
# https://resend.com → API Keys.
RESEND_API_KEY="re_xxxxxxxx"
# Verified sender (e.g. notifikasi@yourdomain.com). While testing you may use
# "onboarding@resend.dev". Recipient = where order/story alerts are sent.
RESEND_FROM="ProofSpeak <onboarding@resend.dev>"
RESEND_TO="owner@example.com"

# --- Admin session ---
# Random 32+ char secret. Generate: openssl rand -base64 32
SESSION_SECRET="change-me-to-a-long-random-string"
# Initial admin login. Change the password after first login (Settings).
ADMIN_EMAIL="admin@proofspeak.id"
ADMIN_PASSWORD="change-me"

# --- Public site URL (used in emails) ---
NEXT_PUBLIC_SITE_URL="http://localhost:3000"
